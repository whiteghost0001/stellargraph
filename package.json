{
  "name": "stellargraph",
  "version": "1.0.0",
  "description": "StellarGraph - High-performance indexer for auditing financial movements on Stellar/Soroban network",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix"
  },
  "keywords": ["stellar", "soroban", "blockchain", "indexer", "audit", "financial", "stellargraph"],
  "author": "StellarGraph Team",
  "license": "MIT",
  "dependencies": {
    "@stellar/stellar-sdk": "^11.2.2",
    "@prisma/client": "^5.7.1",
    "express": "^4.18.2",
    "graphql": "^16.8.1",
    "apollo-server-express": "^3.12.1",
    "winston": "^3.11.0",
    "dotenv": "^16.3.1",
    "axios": "^1.6.2",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/node": "^20.10.4",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.8",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.13.1",
    "@typescript-eslint/parser": "^6.13.1",
    "prisma": "^5.7.1"
  }
}